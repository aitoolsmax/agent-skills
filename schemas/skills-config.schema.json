{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aitoolsmax/agent-skills/blob/main/schemas/skills-config.schema.json",
  "title": "AI Tools Max agent skill catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog", "platforms", "skills"],
  "properties": {
    "$schema": { "type": "string" },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "repository", "license", "supportEmail", "defaultBranch"],
      "properties": {
        "owner": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" },
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "license": { "const": "Apache-2.0" },
        "supportEmail": { "type": "string", "format": "email" },
        "defaultBranch": { "type": "string", "minLength": 1 }
      }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "mode"],
        "properties": {
          "enabled": { "type": "boolean" },
          "mode": { "type": "string" },
          "priority": { "type": "integer", "minimum": 0 },
          "deploy": { "type": "boolean" },
          "reason": { "type": "string" },
          "endpoint": { "type": "string" },
          "listingBase": { "type": "string" }
        }
      }
    },
    "releases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "releasedAt", "platforms"],
        "properties": {
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "releasedAt": { "type": "string", "format": "date" },
          "platforms": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true,
              "required": ["state"],
              "properties": {
                "state": { "type": "string", "minLength": 1 },
                "url": { "type": ["string", "null"] },
                "verification": { "type": "string" },
                "next": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "description", "actorId", "canonicalPath", "version", "tags", "releaseValidation", "userAgents"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 20 },
          "actorId": { "type": "string", "pattern": "^[A-Za-z0-9_-]+/[A-Za-z0-9_-]+$" },
          "canonicalPath": { "type": "string", "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "tags": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "releaseValidation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["liveActorSmokeTest", "maxItems", "budgetUsdPerSkill", "timeoutSeconds", "smokeInput"],
            "properties": {
              "liveActorSmokeTest": { "type": "boolean" },
              "maxItems": { "const": 1 },
              "budgetUsdPerSkill": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
              "timeoutSeconds": { "type": "integer", "minimum": 30, "maximum": 300 },
              "smokeInput": {
                "type": "object",
                "required": ["maxItems"],
                "properties": {
                  "mode": { "enum": ["channels", "search", "category", "livestreams"] },
                  "maxItems": { "const": 1 }
                }
              }
            }
          },
          "userAgents": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 3 },
            "required": ["canonical", "apifyAwesomeSkills"]
          }
        }
      }
    }
  }
}
